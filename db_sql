CREATE TABLE kullanicilar (
    id INT AUTO_INCREMENT PRIMARY KEY,
    kullanici_adi VARCHAR(50) NOT NULL UNIQUE,
    email VARCHAR(100) NOT NULL UNIQUE,
    sifre_hash VARCHAR(255) NOT NULL,
    olusturma_tarihi TIMESTAMP DEFAULT CURRENT_TIMESTAMP
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_turkish_ci;

CREATE TABLE eserler (
    id INT AUTO_INCREMENT PRIMARY KEY,
    eser_adi VARCHAR(255) NOT NULL,
    sanatci VARCHAR(255) NOT NULL,
    yil VARCHAR(50) NOT NULL,
    tur VARCHAR(100) NOT NULL,
    aciklama TEXT,
    gorsel_yolu VARCHAR(255),
    eklenme_tarihi TIMESTAMP DEFAULT CURRENT_TIMESTAMP
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_turkish_ci;

CREATE TABLE favoriler (
    id INT AUTO_INCREMENT PRIMARY KEY,
    kullanici_id INT NOT NULL,
    eser_id INT NOT NULL,
    eklenme_tarihi TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (kullanici_id) REFERENCES kullanicilar(id) ON DELETE CASCADE,
    FOREIGN KEY (eser_id) REFERENCES eserler(id) ON DELETE CASCADE,
    UNIQUE KEY tek_favori (kullanici_id, eser_id)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_turkish_ci;

CREATE TABLE yorumlar (
    id INT AUTO_INCREMENT PRIMARY KEY,
    kullanici_id INT NOT NULL,
    eser_id INT NOT NULL,
    icerik TEXT NOT NULL,
    olusturma_tarihi TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (kullanici_id) REFERENCES kullanicilar(id) ON DELETE CASCADE,
    FOREIGN KEY (eser_id) REFERENCES eserler(id) ON DELETE CASCADE
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_turkish_ci;


INSERT INTO eserler (eser_adi, sanatci, yil, tur, aciklama) VALUES
('Carnation, Lily, Lily, Rose', 'John Singer Sargent', '1886', 'Tablo', 'Amerikalı ressam John Singer Sargent’ın 1885–1886 yıllarında yaptığı Carnation, Lily, Lily, Rose adlı ünlü yağlı boya tablo, alacakaranlıkta beyaz elbiseler içinde kağıt fenerleri yakan iki küçük kız çocuğunu güller, karanfiller ve zambaklarla dolu bir bahçede tasvir eder. Ressamın "Madame X" tablosunun yarattığı skandaldan kaçıp yerleştiği İngiltere’deki bir köy evinde yapılan eser, adını dönemin popüler bir şarkısının nakaratından alır. Sargent, akşamüstünün o büyüleyici ışık anını yakalayabilmek için izlenimci bir teknikle her gün sadece birkaç dakika çalışmış, mevsim geçip çiçekler solduğunda ise yerine yapaylarını koyarak resmi iki yılda tamamlamıştır. İlk sergilendiğinde Fransız tarzı nedeniyle bazı eleştiriler alsa da büyük beğeni toplayarak sanatçının bir kamu müzesi tarafından satın alınan ilk eseri olmuş ve günümüzde Londra’daki Tate Britain müzesinin koleksiyonunda yerini almıştır.'),
('The Empire of Light', 'René Magritte', '1939 – 1967', 'Tablo', 'New York’taki Modern Sanat Müzesi ve Brüksel’deki Belçika Kraliyet Güzel Sanatlar Müzeleri’nde bulunanlar gibi pek çok farklı versiyonu mevcut olan Işıkların İmparatorluğu (Empire of Light) adlı eserde; karanlık, gece vaktine ait bir sokak sahnesi, pamuksu kümülüs bulutlarıyla bezeli, pastel mavi renkte ve ışıkla yıkanan bir gökyüzünün önüne yerleştirilmiştir. René Magritte, gece ile gündüzün bu tek, paradoksal kombinasyonu dışında hiçbir fantastik unsura yer vermeyerek, hayatın temel bir düzenleyici kuralını altüst eder. Normal şartlarda berraklığın ve açıklığın kaynağı olan güneş ışığı, burada geleneksel olarak karanlıkla ilişkilendirilen kafa karışıklığına ve huzursuzluğa neden olur. Gökyüzünün parlaklığı tekinsiz bir hal alarak, aşağıdaki ıssız karanlığı normal bir bağlamda görüneceğinden çok daha aşılmaz kılar. Bu tuhaf konu; gerçekçi (veristik) Sürrealist resmin tipik bir örneği olan ve Magritte’in 1920’lerin ortalarından beri tercih ettiği, nesnel ve titiz bir üslupla ele alınmıştır.'),
('The Weight of Thoughts', 'Thomas Lerooy', '2009', 'Heykel', 'Belçikalı sanatçı Thomas Lerooy’un Paris’teki Petit Palais’de sergilenen "The Weight of Thoughts" (Düşüncelerin Ağırlığı) adlı bronz heykeli, klasik Roma heykellerini andıran bir erkek vücudunun üzerinde, yer çekimine meydan okurcasına duran devasa ve abartılı bir insan kafasını tasvir eder. Sanatçı, bu grotesk tezatlıkla insanın zihinsel süreçlerini, varoluşsal sancılarını, taşımakta zorlandığı fikirleri ve aşırı düşünmenin (overthinking) yarattığı o ezici yükü görsel bir metafora dönüştürür. Klasik sanatın mükemmellik anlayışını mizahi ve sürrealist bir eleştiriyle harmanlayan eser, bedenin hafifliği ile zihnin ağırlığı arasındaki amansız mücadeleyi ve insan zihninin kendi kendini nasıl tutsak edebileceğini etkileyici bir sadelikle gözler önüne serer.'),
('Black Square', 'Kazimir Maleviç', '1915', 'Tablo', 'Rus avangart sanatçısı Kazimir Maleviç’in Black Square (Siyah Kare) tablosu, modern ve soyut sanatın en önemli dönüm noktalarından biridir. Sanatı nesnel dünyanın bağlarından koparmayı amaçlayan Suprematizm akımının doğuşunu simgeleyen bu eser, ilk kez sergilendiğinde geleneksel dini ikonların yerine asılarak büyük bir kural yıkımı gerçekleştirmiştir. İlhamını sanatçının 1913’teki bir opera tasarımı için çizdiği eskizlerden alan ve Maleviç tarafından resmin "sıfır noktası" olarak nitelendirilen çalışmanın, zaman içinde yapılmış toplam dört farklı yağlı boya versiyonu bulunur. 2015’teki X-ışını incelemelerinde altında gizli iki farklı resim ve mizahi bir not olduğu keşfedilen ikonik eser, Sovyetler Birliği’nde Stalin döneminde uzun yıllar yasaklanmış olsa da günümüzde minimalist sanatı derinden etkileyen 20. yüzyılın en tanınmış şaheserleri arasında yer alır.'),
("Mona Lisa", "Leonardo da Vinci", "1503", "Tablo", "İtalyan rönesans sanatçısı Leonardo da Vinci’nin 1503–1506 yılları arasında kavak bir panel üzerine yağlı boyayla resmettiği Mona Lisa (La Gioconda), dünyada en çok bilinen ve en çok ziyaret edilen sanat şaheseridir. Geleneksel olarak Floransalı ipek tüccarı Francesco del Giocondo’nun eşi Lisa del Giocondo’yu tasvir ettiği kabul edilen eser; modelin gizemli gülümsemesi, hatları yumuşatan dumanlı geçiş (sfumato) tekniği, kaşlarının ve kirpiklerinin olmaması ile arkasındaki hayali/buzlu manzara derinliğiyle ünlüdür. 1911 yılında Vincenzo Peruggia tarafından çalınmasıyla küresel bir şöhrete kavuşan tablo, tarihi sigorta değeriyle dünyanın en pahalı sanat eserlerinden biri ünvanını taşır. Leonardo’nun ölümünün ardından Fransız kraliyetine geçen ve 1797’den beri Paris’teki Louvre Müzesi’nde sergilenen bu ikonik portre, günümüzde de insan gözünün algı sınırlarını zorlayan optik yapısı ve kimlik tartışmalarıyla gizemini korumaktadır."),
("The Starry Night", "Vincent van Gogh", "1889", "Tablo", "Hollandalı art izlenimci ressam Vincent van Gogh’un Haziran 1889’da, zihinsel sıkıntıları nedeniyle kaldığı Saint-Rémy-de-Provence’taki akıl hastanesinin odasından gün doğumundan hemen önce görünen doğu manzarasını tasvir ettiği The Starry Night (Yıldızlı Gece), modern batı sanatının en tanınmış başyapıtlarından biridir. Sanatçının stüdyosunda gündüz vakti yaptığı bu tek gece çalışması; içsel çalkantılarını yansıtan girdaplı gökyüzünü, dönemin şafağında parıldayan gerçek Venüs (Sabah Yıldızı) gezegenini, stilize edilmiş bir hilali ve ön planda boyutları abartılmış selvi ağaçlarını içerirken, arka plandaki küçük kasaba ise odasından görünmeyen ve memleketi Hollanda’ya duyduğu özlemle harmanladığı tamamen hayali bir eklentidir. Van Gogh’un mektuplarında bir 'başarısızlık' olarak nitelendirmesine rağmen bilimsel olarak kobalt, ultramarin mavi ve çinko sarısı gibi yoğun renk kontrastlarıyla incelenen eser, kardeşinin ölümünün ardından aile mirası olarak el değiştirmiş, 1941 yılında New York’taki Modern Sanat Müzesi (MoMA) kalıcı koleksiyonuna katılmış olup günümüzde çok nadiren ödünç verilen en ikonik şaheserler arasında yer alır."),
("The Persistence of Memory", "Salvador Dalí", "1931", "Tablo", "İspanyol sanatçı Salvador Dalí’nin 1931 yılında yaptığı ve sürrealizmin en ikonik örneklerinden biri olan The Persistence of Memory (Belleğin Azmi / Eriyen Saatler), eriyen cep saatleri imgesi üzerinden zaman ve mekânın göreceliğini, kozmik düzenin çöküşünü tasvir eden bir başyapıttır. Dalí’nin popüler inanışın aksine Einstein’ın rölativite teorisinden değil, güneşte eriyen bir Camembert peynirinden ilham aldığını belirttiği bu eserde, merkeze yerleştirilen çarpık nesne aslında sanatçının kendi rüyadaki yüzünü simgelerken; sol alttaki erimeyen turuncu saatin üzerindeki karıncalar çürümeyi, üzerindeki sinek insan gölgesi düşüren detayları ve arka plandaki kayalıklar ise ressamın memleketi Katalonya’daki Cap de Creus manzarasını temsil eder. Dalí’nin kendi zihninde sanatsal sanrılar yarattığı 'paranoyak-eleştirel yöntem' döneminde ürettiği, bilinçaltı ile rüya aleminin zamansızlığını titiz bir üslupla aktaran bu gizemli tablo, 1934 yılında yapılan anonim bir bağıştan beri New York’taki Modern Sanat Müzesi (MoMA) bünyesinde kalıcı olarak sergilenmektedir."),
("The Scream", "Edvard Munch", "1893", "Tablo", "Norveçli dışavurumcu ressam Edvard Munch’un 1893 tarihli başyapıtı Çığlık (Skrik / The Scream), modern insanın varoluşsal kaygısını ve ıstırabını simgeleyen sanat tarihinin en ikonik imgelerinden biridir. Sanatçının Oslo'da gün batımında yürürken bulutların kan kırmızısına dönmesiyle hissettiği 'doğadan yükselen sonsuz çığlığı' tasvir ettiği eser, fiyort manzarası önünde elleriyle kafasını tutan ve bir Peru mumyasından esinlenildiği öne sürülen merkezdeki figürüyle tanınır. Munch bu temanın iki yağlı boya, iki pastel ve bir taşbaskı versiyonunu üretmiş; pastel versiyonlardan biri 2012'de rekor bir fiyata satılırken, yağlı boya versiyonları ise 1994 ve 2004 yıllarında büyük yankı uyandıran yüksek profilli hırsızlıkların hedefi olmuş ancak daha sonra bulunmuştur. Günümüzde dışavurumculuk akımının temel taşı kabul edilen bu sarsıcı tablo, Oslo'daki Ulusal Galeri ve Munch Müzesi koleksiyonlarında sergilenmektedir."),
("Kaplumbağa Terbiyecisi", "Osman Hamdi Bey", "1906", "Tablo", "Türk resim sanatının öncülerinden Osman Hamdi Bey’in 1906 ve 1907 yıllarında iki farklı versiyonunu çizdiği Kaplumbağa Terbiyecisi (orijinal adıyla Kaplumbağalar ve Adam), Osmanlı modernleşme sancılarını ve sanatın dönüştürücü gücünü simgeleyen en ünlü başyapıtlardan biridir. Bursa’daki Yeşil Camii’nin bakımsız bir odasında, sırtında nakkare ve elinde ney ile dikilen kırmızı cübbeli derviş kıyafetli bir adamı (ressamın kendisini) ve ayaklarının dibindeki kaplumbağaları tasvir eden eser; geri kalmış bir toplumu sanat, okul ve müze yoluyla çağdaşlaştırmaya çalışan yorgun bir aydının sabrını ve zorluklarını hicveder. Değişime direnen astlarını veya halkı kaplumbağalarla sembolize eden Osman Hamdi Bey'in bu resmi yaparken, Fransız Tour du Monde dergisinde gördüğü Japon esintili bir gravürden (Charmeur de tortues) esinlendiği düşünülmektedir. Doğu ve Batı estetiğini derviş sabrı metaforuyla harmanlayan bu tarihi tablo, günümüzde Türk sanat tarihinin en popüler ve üzerine en çok konuşulan görsel simgelerinden biri olma özelliğini korumaktadır."),
("İnci Küpeli Kız", "Johannes Vermeer", "1665", "Tablo", "Hollandalı ressam Johannes Vermeer’in 1665 yılı civarında tuval üzerine resmettiği ve 'Kuzeyin Mona Lisa'sı' olarak anılan İnci Küpeli Kız (Meisje met de parel), barok döneminin en gizemli ve büyüleyici başyapıtlarından biridir. Karanlık bir arka plan önünde, izleyiciye doğru masum ve davetkar bir bakış atan, dudakları hafifçe aralık genç bir kızı tasvir eden eser; egzotik Türk sarığı tarzındaki mavi-sarı eşarbı ve odak noktası olan iri, parlak inci küpesiyle dikkat çeker. Tablodaki kızın ressamın kızı mı, hizmetçisi mi yoksa tamamen hayal ürünü bir model mi olduğu bugün bile gizemini korurken, eser 'IVMeer' şeklinde imzalansa da tarih taşımamaktadır. Yaklaşık iki yüzyıl boyunca nerede olduğu bilinmeyen, ancak 1881 yılında bir koleksiyoncu tarafından çok ucuza satın alınıp daha sonra müzeye bağışlanan bu ikonik portre, 1902 yılından beri Lahey'deki Mauritshuis Kraliyet Resim Galerisi'nde kalıcı olarak sergilenmektedir."),
("Ivan the Terrible and His Son Ivan", "Ilya Repin", "1885", "Tablo", "Rus gerçekçi ressam İlya Repin’in 1883–1885 yılları arasında tuval üzerine yaptığı Ivan the Terrible and His Son Ivan on 16 November 1581 (Korkunç İvan ve Oğlu İvan), Rus sanat tarihinin en güçlü, trajik ve tartışmalı başyapıtlarından biridir. Eser, Rus Çarı Korkunç İvan'ın bir öfke krizi anında oğlunun kafasına ölümcül bir darbe indirdikten hemen sonra, pişmanlık ve derin bir acı içinde ölmekte olan oğlu Tsareviç İvan'a sarılışını tasvir eder. Repin bu kanlı sahneyi kurgularken; 1881 yılında Çar II. Aleksandr'ın suikastına tanık olmasının yarattığı toplumsal şiddet atmosferinden, Rimski-Korsakov'un intikam temalı müziğinden ve Avrupa seyahatinde izlediği boğa güreşlerinden ilham almıştır. Ressamın, Korkunç İvan için yakın arkadaşı ressam Grigoriy Myasoyedov'u, kurban olan oğlu için ise yüzünde trajik bir kader gördüğü yazar Vsevolod Garşin'i model olarak kullandığı bu sarsıcı tablo, bitirilmesinin ardından Pavel Tretyakov tarafından satın alınmıştır ve günümüzde Moskova'daki Tretyakov Galerisi'nde sergilenmektedir."),
("The Creation of Adam", "Michelangelo", "1512", "Tablo", "İtalyan rönesans dâhisi Michelangelo’nun 1508–1512 yılları arasında Vatikan’daki Sistine Şapeli’nin tavanına resmettiği The Creation of Adam (Adem’in Yaradılışı), dünya sanat tarihinin en çok çoğaltılan ve taklit edilen dini freskidir. Eser, İncil’deki yaratılış hikayesinden yola çıkarak Tanrı’nın ilk insan olan Adem’e can verme anını tasvir eder. Sağda uçuşan pelerinler içindeki güçlü Tanrı figürü ile solda uzanmış çıplak Adem’in birbirine uzanan işaret parmakları arasındaki o çok küçük boşluk, ilahi güç ile insan arasındaki bağı ve mükemmelliğin ulaşılamazlığını simgeler. Papa II. Julius’un zorlamasıyla Michelangelo’nun aslında çok iyi bilmediği fresk tekniğiyle tek başına tamamladığı bu devasa tavan çalışması, kusursuz anatomik detayları ve insan-tanrı ilişkisini ele alış biçimiyle günümüzde de Vatikan’ın en büyük gururu olarak hayranlık uyandırmaya devam etmektedir."),
("Dokuzuncu Dalga", "Ivan Ayvazovski", "1850", "Tablo", "Rus deniz ressamı Ivan Aivazovsky’nin 1850 yılında tamamladığı The Ninth Wave (Dokuzuncu Dalga), sanatçının en ünlü başyapıtıdır. Adını denizcilikte peş peşe gelen dalgaların ardından patlayan en büyük ve en yıkıcı dalgayı ifade eden eski bir inanıştan alan eser; gece patlayan korkunç bir fırtınanın ardından batmakta olan bir geminin enkazına, yani Hristiyanlıkta kurtuluşu simgeleyen haç şeklindeki bir direğe tutunarak hayatta kalmaya çalışan bir grup insanı tasvir eder. Doğanın hem vahşi yıkımını hem de büyüleyici güzelliğini gözler önüne seren bu ikonik tabloda, yükselen sabah güneşinin yarattığı sıcak tonlar denizin o tehditkar havasını hafifleterek kazazedelerin kurtulma umudunun hâlâ var olduğunu hissettirir."),
("Düşünen Adam", "Auguste Rodin", "1904", "Heykel", "Fransız heykeltıraş Auguste Rodin’in ilk olarak 1880 yılında Dante’nin İlahi Komedya’sından esinlenen Cehennem Kapıları adlı anıtsal eseri için 'Şair' adıyla tasarladığı The Thinker (Düşünen Adam), günümüzde felsefe ve derin tefekkürün dünya çapındaki en ikonik simgesidir. Model olarak kaslı bir boksör olan Jean Baud’un kullanıldığı bu bronz heykel, kayalık bir zemine oturup sağ dirseğini sol uyluğuna yaslayarak elinin arkasıyla çenesini tutan, çıplak og atletik bir erkek figürünün derin düşüncelere dalışını tasvir eder. Rodin’in entelektüel gücü ve şiirselliği Michelangelo geleneğinde kahramansı bir çıplaklıkla harmanladığı bu eser, dökümhane işçilerinin Michelangelo’nun başka bir heykeline benzetmesiyle bugünkü adını almış ve modern heykel sanatının öncüsü olmuştur. İlk büyük boyutlu anıtsal dökümü 1904 yılında yapılan ve sanatçının gözetimi dışında üretilenlerle birlikte dünya genelinde 28 tam boyutlu bronz kopyası bulunan bu başyapıtın orijinali Paris’teki Musée Rodin’de sergilenmektedir."),
("Ali ve Nino", "Tamara Kvesitadze", "2007", "Heykel", "Gürcü heykeltıraş Tamara Kvesitadze tarafından 2007 yılında tasarlanan bu hareketli metal başyapıt, ilk olarak aynı yıl Venedik Bienali'nde 'Kadın ve Erkek' adıyla sergilenmiş ve büyük beğeni toplamıştır. Sanatçının kendi web sitesinde halen orijinal ismiyle anılan bu kinetik heykel, 2010 yılında Gürcistan'ın Batum şehrine kalıcı olarak yerleştirilmiştir. Eser, kurulumunun ardından Kurban Said’in dünyaca ünlü 'Ali ve Nino' romanından esinlenerek yeniden adlandırılmıştır. Roman, Müslüman bir Azeri genci ile Hristiyan bir Gürcü kızı arasındaki trajik ve imkansız aşkı konu alır. Kvesitadze'nin çelik levhalarla tasarladığı figürler, mekanik bir hareketle her akşam birbirine doğru yaklaşır, kısa bir an için kucaklaşır, birbirlerinin içinden geçip gider ve sonunda yeniden ayrılırlar; bu döngü, kavuşamayan aşıkların zamansız hikayesini somutlaştırır."),
("Venus de Milo", "Alexandros of Antioch", "MÖ 100", "Heykel", "Antik Yunan sanatının Helenistik dönemine (MÖ 2. yüzyıl) ait olan ve 1820 yılında Yunanistan’ın Milos Adası’nda keşfedilen Venus de Milo (Milo Venüsü), dünya çapında antik heykel sanatının en tanınmış başyapıtlarından biridir. Yunan aşk tanrıçası Afrodit’i tasvir ettiği kabul edilen ve Parian mermerinden gerçek boyutların üzerinde (2 metreden uzun) yontulan bu ikonik heykel, çıplak üst bedeni ve alt kısmını örten dumanlı kumaş kıvrımlarıyla klasik ve Helenistik üslupları kusursuzca harmanlar. Keşfedildiğinde yanında bir elma tutan mermer el parçası bulunmasına rağmen, iki kolunun da eksik olması nedeniyle orijinal duruşu ve kollarının pozisyonu bugün hâlâ kesin olarak bilinmemektedir. Napolyon Savaşları’nın ardından Paris’teki Louvre Müzesi’nin antik koleksiyonunun temel taşı haline gelen, düzinelerce şiire ve modern sürrealist akıma ilham veren bu anıtsal şaheser, 1821 yılından beri aynı müzede kalıcı olarak sergilenmekte ve gizemli eksikliğiyle hayranlık uyandırmaya devam etmektedir.");


